rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Predictions: Users can create, read, and list their own predictions.
    match /predictions/{predictionId} {
      allow read, create: if isOwner(request.resource.data.userId);
    }
    match /predictions/{wildcard=**} {
      allow list: if isSignedIn();
    }

    // Health Logs: Users can create, read, and list their own health logs.
    match /healthLogs/{logId} {
      allow read, create: if isOwner(request.resource.data.userId);
    }
    match /healthLogs/{wildcard=**} {
      allow list: if isSignedIn();
    }

    // Quiz Attempts: Users can create, read, and list their own quiz attempts.
    match /quizAttempts/{attemptId} {
       allow read, create: if isOwner(request.resource.data.userId);
    }
     match /quizAttempts/{wildcard=**} {
      allow list: if isSignedIn();
    }

    // Contact Queries: Users can create their own queries.
    match /contactQueries/{queryId} {
        allow create: if isOwner(request.resource.data.userId);
    }

    // Timelines: Users can create, read and list timelines associated with their predictions.
    match /timelines/{timelineId} {
      allow read, create: if isOwner(request.resource.data.userId);
    }
     match /timelines/{wildcard=**} {
      allow list: if isSignedIn();
    }
  }
}

